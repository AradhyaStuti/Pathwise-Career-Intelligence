PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/pathwise
JWT_SECRET=replace-with-long-random-string
GROQ_API_KEY=your-groq-key-from-console.groq.com
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
# Optional — Gemini is used as a third fallback when both Groq models hit daily limits
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
# Optional — Cerebras (free Llama 3.3 70B, blazing fast). https://cloud.cerebras.ai/
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.3-70b
# Optional — OpenRouter (free models). https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
FRONTEND_URL=http://localhost:5173
